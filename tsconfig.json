{
  "compilerOptions": {
    "module": "esnext",
    "noEmit": true,
    "target": "esnext",
    "sourceMap": true,
    "declaration": false,
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "types": [
      "mbler/client"
    ]
  },
  "include": [
    "./behavior/scripts/**/*"
  ]
}
